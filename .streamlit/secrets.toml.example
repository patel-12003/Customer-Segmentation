# =============================================================================
# Streamlit Secrets Configuration - Example
# =============================================================================
# 
# To use this file:
# 1. Copy this file and rename it to 'secrets.toml' (without .example)
# 2. Fill in your actual API keys and credentials
# 3. The secrets.toml file is gitignored and will not be committed
#
# For production deployment (Streamlit Cloud):
# Add these secrets through the Streamlit Cloud dashboard under App Settings > Secrets
# =============================================================================

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY = "your-gemini-api-key-here"

# Optional: Override default Gemini model settings
# GEMINI_MODEL_NAME = "gemini-1.5-flash"
# GEMINI_TEMPERATURE = "0.7"
# GEMINI_MAX_TOKENS = "2048"
# GEMINI_RATE_LIMIT = "10"
